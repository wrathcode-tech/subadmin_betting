# Server port for dev (npm start)
PORT=5010

# App title (shown in UI)
REACT_APP_TITLE=Bookie Subadmin

# Backend API base URL
REACT_APP_API_URL=http://localhost:5010/api

# Games list - comma-separated
REACT_APP_GAMES=Cricket,Football,Tennis,Horse Racing,Kabaddi

# Optional limits
REACT_APP_MAX_AGENTS=50
REACT_APP_DEFAULT_ODDS_LIMIT=10

# Optional features
REACT_APP_SHOW_REPORTS=true
REACT_APP_SHOW_GAMES=true
